{
  "extends": "./tsconfig.base.json",
  "compilerOptions": {
    "module": "CommonJS",
    "moduleResolution": "node",
    "ignoreDeprecations": "6.0",
    "rootDir": "src",
    "outDir": "dist/cjs",
    "declaration": false
  },
  "include": ["src/**/*.ts"],
  "exclude": [
    "src/**/__tests__",
    "src/**/manual-tests"
  ]
}
